local function getTargets(arg)
    local out={}; arg=arg:lower()
    for _,p in pairs(Players:GetPlayers()) do
        if arg=="all" or p.Name:lower():sub(1,#arg)==arg then table.insert(out,p) end
    end
    return out
end
local function getPlayer(arg)
    arg=arg:lower()
    for _,p in pairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1,#arg)==arg then return p end
    end
end
local function fakeSay(plr,msg)
    local head = plr.Character and plr.Character:FindFirstChild("Head")
    if head then Chat:Chat(head,msg,Enum.ChatColor.White) end
    pcall(function() StarterGui:SetCore("ChatMakeSystemMessage",{Text=plr.Name..": "..msg;Color=Color3.new(1,1,1)}) end)
end
local function spinP(plr)
    local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    task.spawn(function() local s=tick(); while tick()-s<6 and task.wait() do hrp.CFrame=hrp.CFrame*CFrame.Angles(0,math.rad(25),0) end end)
end
local function orbitP(plr)
    local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local myHRP=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart"); if not myHRP then return end
    task.spawn(function() local s=tick(); while tick()-s<8 and task.wait() do local t=tick()*2; hrp.CFrame=CFrame.new(myHRP.Position+Vector3.new(math.cos(t)*5,0,math.sin(t)*5),myHRP.Position) end end)
end
local function sparkleP(plr)
    local hrp=plr.Character and plr.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return end
    local p=Instance.new("ParticleEmitter"); p.Texture="rbxassetid://241594408"; p.Color=ColorSequence.new(Color3.fromRGB(255,0,255),Color3.fromRGB(130,60,220)); p.Rate=40; p.Lifetime=NumberRange.new(0.4,0.6); p.Speed=NumberRange.new(1,3); p.Parent=hrp
    task.delay(8,function() if p then p:Destroy() end end)
end

cmdBox.FocusLost:Connect(function(enter)
    if not enter or ROLES[LocalPlayer.Name]~="Owner" then return end
    local text=cmdBox.Text:lower(); cmdBox.Text=""
    if text:sub(1,1)==";" then text=text:sub(2) end
    local parts={}; for t in text:gmatch("%S+") do table.insert(parts,t) end
    local cmd=parts[1]; local arg=parts[2] or ""
    if not cmd then cmdBox:CaptureFocus(); return end

    if cmd=="freeze" then for _,p in pairs(getTargets(arg)) do
        local h=p.Character and p.Character:FindFirstChildOfClass("Humanoid"); if h then h.WalkSpeed=0;h.JumpPower=0 end
    end
    elseif cmd=="unfreeze" then for _,p in pairs(getTargets(arg)) do
        local h=p.Character and p.Character:FindFirstChildOfClass("Humanoid"); if h then h.WalkSpeed=16;h.JumpPower=50 end
    end
    elseif cmd=="say" then
        local msg=table.concat(parts," ",3)
        for _,p in pairs(getTargets(arg)) do fakeSay(p,msg) end
    elseif cmd=="spin" then local p=getPlayer(arg); if p then spinP(p) end
    elseif cmd=="orbit" then local p=getPlayer(arg); if p then orbitP(p) end
    elseif cmd=="sparkle" then local p=getPlayer(arg); if p then sparkleP(p) end
    elseif cmd=="tpme" then
        local p=getPlayer(arg)
        if p then
            local myHRP=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local tHRP=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if myHRP and tHRP then TweenService:Create(myHRP,TweenInfo.new(0.25),{CFrame=tHRP.CFrame*CFrame.new(0,0,-3)}):Play() end
        end
    elseif cmd=="tphere" then
        local p=getPlayer(arg)
        if p then
            local myHRP=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local tHRP=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
            if myHRP and tHRP then TweenService:Create(tHRP,TweenInfo.new(0.25),{CFrame=myHRP.CFrame*CFrame.new(0,0,-3)}):Play() end
        end
    elseif cmd=="spam" then
        local msg=table.concat(parts," ",3)
        local p=getPlayer(arg)
        if p and msg~="" then for i=1,10 do fakeSay(p,msg); task.wait(0.15) end end
    end
    cmdBox:CaptureFocus()
end)

