local function typewriter(lbl, fullText, delay)
    lbl.Text = ""
    for i = 1, #fullText do
        lbl.Text = string.sub(fullText,1,i)
        task.wait(delay)
    end
end

local function hookDistVis(billboard, lbl)
    local head = billboard.Adornee
    if not head then return end
    RunService.RenderStepped:Connect(function()
        if not head.Parent or not billboard.Parent then return end
        local dist = (Camera.CFrame.Position - head.Position).Magnitude
        local t = dist > FAR_HIDE_DIST and 1 or 0
        lbl.TextTransparency      = t
        lbl.TextStrokeTransparency = t == 0 and 0.35 or 1
    end)
end

