    local FP=TabPages["Fly"]
    local function StopFly()
        FlyActive=false
        if FlyConn then FlyConn:Disconnect();FlyConn=nil end
        if FlyBV then FlyBV:Destroy();FlyBV=nil end
        if FlyBG then FlyBG:Destroy();FlyBG=nil end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.PlatformStand=false end
    end
    local function StartFly(mode)
        StopFly(); FlyActive=true
        local char=LocalPlayer.Character; if not char then return end
        local hrp=char:FindFirstChild("HumanoidRootPart"); local hum=char:FindFirstChild("Humanoid"); if not hrp or not hum then return end
        hum.PlatformStand=true
        FlyBV=Instance.new("BodyVelocity");FlyBV.MaxForce=Vector3.new(1e9,1e9,1e9);FlyBV.Velocity=Vector3.zero;FlyBV.Parent=hrp
        FlyBG=Instance.new("BodyGyro");FlyBG.MaxTorque=Vector3.new(1e9,1e9,1e9);FlyBG.D=100;FlyBG.Parent=hrp
        FlyConn=RunService.Heartbeat:Connect(function()
            if not FlyActive or not hrp or not hrp.Parent then StopFly();return end
            local spd=State.FlySpd or 50; local vel=Vector3.zero
            local W=UserInputService:IsKeyDown(Enum.KeyCode.W); local S=UserInputService:IsKeyDown(Enum.KeyCode.S)
            local A=UserInputService:IsKeyDown(Enum.KeyCode.A); local D=UserInputService:IsKeyDown(Enum.KeyCode.D)
            local UP=UserInputService:IsKeyDown(Enum.KeyCode.Space); local DN=UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
            if mode=="Normal" then
                if W then vel=vel+Camera.CFrame.LookVector*spd end; if S then vel=vel-Camera.CFrame.LookVector*spd end
                if A then vel=vel-Camera.CFrame.RightVector*spd end; if D then vel=vel+Camera.CFrame.RightVector*spd end
                if UP then vel=vel+Vector3.new(0,spd,0) end; if DN then vel=vel-Vector3.new(0,spd,0) end
                FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
            elseif mode=="Superman" then
                if W then vel=vel+Camera.CFrame.LookVector*spd end; if S then vel=vel-Camera.CFrame.LookVector*spd end
                if A then vel=vel-Camera.CFrame.RightVector*spd end; if D then vel=vel+Camera.CFrame.RightVector*spd end
                if UP then vel=vel+Vector3.new(0,spd,0) end; if DN then vel=vel-Vector3.new(0,spd,0) end
                FlyBV.Velocity=vel
                local flat=Vector3.new(Camera.CFrame.LookVector.X,0,Camera.CFrame.LookVector.Z)
                if flat.Magnitude>0 then flat=flat.Unit end
                FlyBG.CFrame=CFrame.new(hrp.Position,hrp.Position+flat)*CFrame.Angles(-math.rad(80),0,0)
            elseif mode=="Speed Fly" then
                spd=spd*3
                if W then vel=vel+Camera.CFrame.LookVector*spd end; if S then vel=vel-Camera.CFrame.LookVector*spd end
                if A then vel=vel-Camera.CFrame.RightVector*spd end; if D then vel=vel+Camera.CFrame.RightVector*spd end
                if UP then vel=vel+Vector3.new(0,spd,0) end; if DN then vel=vel-Vector3.new(0,spd,0) end
                FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
            elseif mode=="Noclip Fly" then
                if W then vel=vel+Camera.CFrame.LookVector*spd end; if S then vel=vel-Camera.CFrame.LookVector*spd end
                if A then vel=vel-Camera.CFrame.RightVector*spd end; if D then vel=vel+Camera.CFrame.RightVector*spd end
                if UP then vel=vel+Vector3.new(0,spd,0) end; if DN then vel=vel-Vector3.new(0,spd,0) end
                FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
                for _,p in pairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
            elseif mode=="Hover" then
                vel=Vector3.new(0,math.sin(tick()*2)*3,0)
                if W then vel=vel+Camera.CFrame.LookVector*(spd*0.6) end; if S then vel=vel-Camera.CFrame.LookVector*(spd*0.6) end
                if A then vel=vel-Camera.CFrame.RightVector*(spd*0.6) end; if D then vel=vel+Camera.CFrame.RightVector*(spd*0.6) end
                FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
            elseif mode=="Glide" then
                if W then vel=vel+Camera.CFrame.LookVector*(spd*0.5) end; if S then vel=vel-Camera.CFrame.LookVector*(spd*0.3) end
                if A then vel=vel-Camera.CFrame.RightVector*(spd*0.4) end; if D then vel=vel+Camera.CFrame.RightVector*(spd*0.4) end
                vel=vel+Vector3.new(0,-4,0); FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
            elseif mode=="Stealth Fly" then
                for _,p in pairs(char:GetDescendants()) do if p:IsA("BasePart") and p.Name~="HumanoidRootPart" then p.LocalTransparencyModifier=1 end end
                if W then vel=vel+Camera.CFrame.LookVector*spd end; if S then vel=vel-Camera.CFrame.LookVector*spd end
                if A then vel=vel-Camera.CFrame.RightVector*spd end; if D then vel=vel+Camera.CFrame.RightVector*spd end
                if UP then vel=vel+Vector3.new(0,spd,0) end; if DN then vel=vel-Vector3.new(0,spd,0) end
                FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
            elseif mode=="Orbit" then
                State.OrbitAngle=(State.OrbitAngle or 0)+0.02
                FlyBV.Velocity=Vector3.new(math.cos(State.OrbitAngle)*(spd*0.5),0,math.sin(State.OrbitAngle)*(spd*0.5))
                FlyBG.CFrame=Camera.CFrame
            elseif mode=="Rocket" then
                FlyBV.Velocity=Vector3.new(0,spd*4,0); FlyBG.CFrame=Camera.CFrame
            elseif mode=="Swim Fly" then
                if W then vel=vel+Camera.CFrame.LookVector*spd end; if S then vel=vel-Camera.CFrame.LookVector*spd end
                vel=vel+Vector3.new(0,math.sin(tick()*4)*8,0)
                FlyBV.Velocity=vel; FlyBG.CFrame=Camera.CFrame
            end
        end)
    end
