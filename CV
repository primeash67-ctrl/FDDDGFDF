-- Only owner can use the bar (others still see it but no effect)
local function handleCommand(text)
    if ROLES[localPlayer.Name] ~= "Owner" then
        return
    end

    text = text:lower()

    local parts = {}
    for token in string.gmatch(text, "%S+") do
        table.insert(parts, token)
    end
    local cmd = parts[1]
    local arg1 = parts[2] or ""

    if cmd == "freeze" and arg1 ~= "" then
        -- freeze <name|all>
        for _, plr in ipairs(getTargetsFromArg(arg1)) do
            setFrozen(plr, true)
        end

    elseif cmd == "say" and arg1 ~= "" then
        -- say <name> <message...>
        local targetName = arg1
        local msg = table.concat(parts, " ", 3)
        if msg ~= "" then
            local targets = getTargetsFromArg(targetName)
            for _, plr in ipairs(targets) do
                fakeSay(plr, msg)
            end
        end
    end
end

commandBar.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        local text = commandBar.Text
        commandBar.Text = ""
        if text ~= "" then
            handleCommand(text)
        end
    end
end)

