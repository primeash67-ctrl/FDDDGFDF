local function try_key(key)
    if not key or key == "" then return false, "Enter a key." end
    if key == VALID_KEY then
        writefile(KS_file, key)
        return true, "Welcome to Ash Hub! 🔥"
    end
    return false, "Wrong key. Try again."
end

