    New("UIPadding",{PaddingTop=UDim.new(0,4),PaddingLeft=UDim.new(0,4),PaddingRight=UDim.new(0,8),Parent=p})
    TabPages[name]=p; return p
end

local function SwitchTab(name)
    CurrentTab=name
    for n,pg in pairs(TabPages) do pg.Visible=(n==name) end
    for n,b in pairs(TabBtns) do
        if n==name then Tween(b,0.15,{BackgroundColor3=Theme.ToggleON,BackgroundTransparency=0,TextColor3=Theme.Text})
        else Tween(b,0.15,{BackgroundColor3=Theme.ToggleOFF,BackgroundTransparency=0.4,TextColor3=Theme.TextDim}) end
    end
end

for i,name in ipairs(Tabs) do
    MakeTabBtn(name,i); MakePage(name)
    TabBtns[name].MouseButton1Click:Connect(function() SwitchTab(name) end)
end

