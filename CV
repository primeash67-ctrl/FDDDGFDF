        Position               = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        Font                   = Enum.Font.GothamBold,
        TextScaled             = true,
        TextXAlignment         = Enum.TextXAlignment.Center,
        TextYAlignment         = Enum.TextYAlignment.Center,
        TextStrokeTransparency = 0.35,
        TextStrokeColor3       = Color3.new(0,0,0),
        Parent                 = cont,
    })

    -- Click to goku-tp
    local click = New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=5,Parent=cont})
    click.MouseButton1Click:Connect(function()
        local myChar = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local myHRP  = myChar:FindFirstChild("HumanoidRootPart")
        local tHRP   = character:FindFirstChild("HumanoidRootPart")
        if myHRP and tHRP then
            TweenService:Create(myHRP, TweenInfo.new(0.25,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {CFrame=tHRP.CFrame*CFrame.new(0,0,-3)}):Play()
        end
    end)

    if role == "Owner" then
        lbl.TextColor3 = Theme.AccentBright

        -- Hood typewriter text
        task.spawn(function()
            typewriter(lbl, "i am only kind 😈", 0.045)
        end)

        -- Pulse the stroke purple → bright → purple
        task.spawn(function()
            while bb.Parent do
                Tween(tagStroke, 0.8, {Color=Theme.AccentBright})
                task.wait(0.8)
                Tween(tagStroke, 0.8, {Color=Theme.Border})
                task.wait(0.8)
            end
        end)

    elseif role == "Admin" then
        lbl.TextColor3 = Theme.Text
        lbl.Text       = "ADMIN 🔥"
        crownHolder.Size = UDim2.new(0,0,0,0)
        tagStroke.Color = Theme.Accent

    else
        lbl.TextColor3 = Theme.TextDim
        lbl.Text       = "USER"
        crownHolder.Size = UDim2.new(0,0,0,0)
        tagStroke.Color = Theme.BorderDim
    end

    hookDistVis(bb, lbl)
end

