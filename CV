    -- Container: transparent background + purple outline
    local cont = New("Frame", {
        Size                  = UDim2.new(1, 0, 1, 0),
        BackgroundColor3      = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.35,    -- see-through like key system
        BorderSizePixel       = 0,
        Parent                = bb,
    })
    Corner(12, cont)

    local tagStroke = New("UIStroke", {
        Color             = Theme.Border,
        Thickness         = 2.5,
